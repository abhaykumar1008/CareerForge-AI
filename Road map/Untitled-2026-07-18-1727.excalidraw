      "text": "Phase 1 → Global CSS\n\n↓\n\nPhase 2 → Common Components\n\n↓\n\nPhase 3 → Individual Pages\n\n↓\n\nPhase 4 → Responsive Design\n\n↓\n\nPhase 5 → Animations\n\n↓\n\nPhase 6 → Theme & Dark Mode\n\n↓\n\nPhase 7 → Optimization",
      "fontSize": 36,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Phase 1 → Global CSS\n\n↓\n\nPhase 2 → Common Components\n\n↓\n\nPhase 3 → Individual Pages\n\n↓\n\nPhase 4 → Responsive Design\n\n↓\n\nPhase 5 → Animations\n\n↓\n\nPhase 6 → Theme & Dark Mode\n\n↓\n\nPhase 7 → Optimization",
      "autoResize": true,
      "lineHeight": 1.25
    },
