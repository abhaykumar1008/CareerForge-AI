      "updated": 1784554265954,
      "link": null,
      "locked": false,
      "text": "css/\n\n│\n\n├── style.css              (Global Styles)\n\n├── variables.css          (Colors & Fonts)\n\n├── reset.css              (Reset Browser CSS)\n\n├── components.css         (Buttons, Cards, Forms)\n\n├── navbar.css\n\n├── sidebar.css\n\n├── footer.css\n\n├── dashboard.css\n\n├── login.css\n\n├── profile.css\n\n├── companies.css\n\n├── roadmap.css\n\n├── certificates.css\n\n├── settings.css\n\n├── admin.css\n\n├── responsive.css\n\n└── animations.css",
      "fontSize": 36,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "css/\n\n│\n\n├── style.css              (Global Styles)\n\n├── variables.css          (Colors & Fonts)\n\n├── reset.css              (Reset Browser CSS)\n\n├── components.css         (Buttons, Cards, Forms)\n\n├── navbar.css\n\n├── sidebar.css\n\n├── footer.css\n\n├── dashboard.css\n\n├── login.css\n\n├── profile.css\n\n├── companies.css\n\n├── roadmap.css\n\n├── certificates.css\n\n├── settings.css\n\n├── admin.css\n\n├── responsive.css\n\n└── animations.css",
